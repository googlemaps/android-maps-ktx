<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/execution_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".execution.SnippetExecutionActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/execution_appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/execution_toolbar"
            style="@style/Widget.MaterialComponents.Toolbar.Primary"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Snippet Verification"
            app:titleTextColor="#FFFFFF" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/execution_map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/execution_appbar" />

    <!-- Semitranslucent Live Location Telemetry HUD Log Panel -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/panel_telemetry"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:cardCornerRadius="8dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#E0202124"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@+id/execution_appbar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/text_telemetry_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STATUS: FLOW ACTIVE STREAMING"
                android:textColor="#00E676"
                android:textStyle="bold"
                android:textSize="13sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="6dp"
                android:background="#3C4043" />

            <TextView
                android:id="@+id/text_telemetry_log"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="[12:00:00] Waiting for KTX stream..."
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.2" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Floating Action Button triggering camera animations on execution views if needed -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_execute_camera"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="@string/btn_animate_camera"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
